/* Modern Admin Dashboard */
.modern-admin {
  display: flex;
  min-height: 100vh;
  background: #1a1d29;
  font-family: 'Cairo', sans-serif;
}

.modern-admin.dark {
  background: #1a1d29;
}

/* Sidebar */
.sidebar {
  width: 80px;
  background: #23283a;
  border-left: 1px solid #2d3748;
  display: flex;
  flex-direction: column;
  position: fixed;
  height: 100vh;
  right: 0;
  top: 0;
  z-index: 100;
  transition: width 0.3s ease;
}

.modern-admin.dark .sidebar {
  background: #23283a;
  border-left-color: #2d3748;
}

.sidebar-header {
  padding: 24px 16px;
  border-bottom: 1px solid #2d3748;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.modern-admin.dark .sidebar-header {
  border-bottom-color: #2d3748;
}

.sidebar-header img {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  object-fit: cover;
}

.sidebar-header h2 {
  display: none;
}

/* Sidebar Navigation */
.sidebar-nav {
  flex: 1;
  padding: 16px;
  overflow-y: auto;
}

.nav-link {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 16px 8px;
  border-radius: 12px;
  text-decoration: none;
  color: #64748b;
  font-weight: 600;
  margin-bottom: 8px;
  transition: all 0.3s ease;
  position: relative;
  font-size: 0.75rem;
}

.modern-admin.dark .nav-link {
  color: #64748b;
}

.nav-link:hover {
  background: #2d3748;
  color: #5b6ee1;
}

.modern-admin.dark .nav-link:hover {
  background: #2d3748;
  color: #5b6ee1;
}

.nav-link.active {
  background: #5b6ee1;
  color: white;
}

.nav-link svg {
  font-size: 1.4rem;
}

.nav-link span {
  font-size: 0.7rem;
}

.nav-link .badge {
  margin-right: auto;
  background: #ef4444;
  color: white;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 700;
}

.logout-btn {
  margin: 16px;
  padding: 14px;
  background: #2d3748;
  color: #f87171;
  border: none;
  border-radius: 12px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-family: 'Cairo', sans-serif;
  transition: all 0.3s ease;
  font-size: 0.75rem;
}

.logout-btn:hover {
  background: #374151;
  color: #ef4444;
}

.logout-btn svg {
  font-size: 1.4rem;
}

/* Main Content */
.main-content {
  flex: 1;
  margin-right: 80px;
  padding: 32px;
  background: #1a1d29;
}

.modern-admin.dark .main-content {
  background: #1a1d29;
}

/* Top Bar */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
  background: #23283a;
  padding: 20px 24px;
  border-radius: 16px;
}

.top-bar-left {
  display: flex;
  align-items: center;
  gap: 20px;
}

.menu-toggle {
  background: none;
  border: none;
  color: white;
  font-size: 1.3rem;
  cursor: pointer;
  padding: 8px;
  display: none;
}

.top-bar-left h1 {
  font-size: 1.8rem;
  font-weight: 800;
  color: white;
  margin: 0;
}

.breadcrumb {
  color: #64748b;
  font-size: 0.9rem;
  margin: 4px 0 0 0;
}

.breadcrumb span:last-child {
  color: #94a3b8;
}

.modern-admin.dark .top-bar-left h1 {
  color: white;
}

.modern-admin.dark .top-bar-left p {
  color: #64748b;
}

.top-bar-right {
  display: flex;
  gap: 12px;
  align-items: center;
}

.date-picker-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: #2d3748;
  border: 1px solid #374151;
  border-radius: 10px;
  color: white;
  font-family: 'Cairo', sans-serif;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.date-picker-btn:hover {
  background: #374151;
}

.user-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid #5b6ee1;
}

.user-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.icon-btn {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  border: none;
  background: #2d3748;
  color: #94a3b8;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  transition: all 0.3s ease;
  position: relative;
}

.modern-admin.dark .icon-btn {
  background: #2d3748;
  color: #94a3b8;
}

.icon-btn:hover {
  background: #374151;
  color: white;
  transform: scale(1.05);
}

.notification-dot {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 8px;
  height: 8px;
  background: #ef4444;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.2);
  }
}

/* Stats Container */
.stats-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 32px;
}

/* Stat Cards - New Design */
.stat-card {
  background: #23283a;
  border-radius: 20px;
  padding: 28px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  border: 1px solid #2d3748;
}

.modern-admin.dark .stat-card {
  background: #23283a;
  border-color: #2d3748;
}

.stat-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
}

.stat-content {
  flex: 1;
}

.stat-label {
  color: #94a3b8;
  font-size: 0.9rem;
  font-weight: 600;
  margin-bottom: 12px;
}

.stat-value {
  font-size: 2.5rem;
  font-weight: 800;
  color: white;
  margin-bottom: 12px;
}

.stat-change {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.85rem;
  font-weight: 600;
}

.stat-change.positive {
  color: #34d399;
}

.stat-change.negative {
  color: #f87171;
}

.stat-change svg {
  font-size: 0.75rem;
}

.stat-icon-circle {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: white;
  flex-shrink: 0;
}

.stat-card.sessions .stat-icon-circle {
  background: linear-gradient(135deg, #5b6ee1, #7c3aed);
}

.stat-card.avg-sessions .stat-icon-circle {
  background: linear-gradient(135deg, #34d399, #10b981);
}

.stat-card.bounce-rate .stat-icon-circle {
  background: linear-gradient(135deg, #f87171, #ef4444);
}

/* Loading Screen */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  gap: 20px;
  background: #1a1d29;
}

.loader {
  width: 60px;
  height: 60px;
  border: 4px solid #2d3748;
  border-top-color: #5b6ee1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-screen p {
  font-size: 1.1rem;
  font-weight: 600;
  color: #94a3b8;
}

/* Responsive Design */
@media (max-width: 1024px) {
  .sidebar {
    width: 80px;
  }

  .main-content {
    margin-right: 80px;
  }

  .stats-container {
    grid-template-columns: repeat(2, 1fr);
  }

  .analytics-section {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .sidebar {
    transform: translateX(100%);
    width: 280px;
  }

  .sidebar.open {
    transform: translateX(0);
  }

  .main-content {
    margin-right: 0;
    padding: 20px;
  }

  .stats-container {
    grid-template-columns: 1fr;
  }

  .analytics-section {
    grid-template-columns: 1fr;
  }

  .top-bar {
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  .nav-link {
    flex-direction: row;
    justify-content: flex-start;
    padding: 14px 16px;
  }

  .nav-link span {
    font-size: 1rem;
  }

  .sidebar-header h2 {
    display: block;
  }
}

@media (max-width: 480px) {
  .stat-card {
    padding: 20px;
  }

  .stat-value {
    font-size: 2rem;
  }

  .analytics-section {
    grid-template-columns: 1fr;
  }

  .device-header,
  .device-row {
    grid-template-columns: 2fr 1fr 1fr;
  }

  .device-header span:last-child,
  .device-row .device-change:last-child {
    display: none;
  }

  .date-picker-btn span {
    display: none;
  }
}

/* Bottom Section */
.bottom-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-top: 32px;
}

/* Top Performers */
.top-performers,
.recent-activity {
  background: white;
  border-radius: 20px;
  padding: 28px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.modern-admin.dark .top-performers,
.modern-admin.dark .recent-activity {
  background: #1e293b;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 2px solid #e2e8f0;
}

.modern-admin.dark .section-header {
  border-bottom-color: #334155;
}

.section-header h2 {
  font-size: 1.3rem;
  font-weight: 800;
  color: #1e293b;
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 0;
}

.modern-admin.dark .section-header h2 {
  color: white;
}

.section-header h2 svg {
  color: #f59e0b;
}

.view-all {
  color: #003DA5;
  font-weight: 600;
  font-size: 0.95rem;
  text-decoration: none;
  transition: all 0.3s ease;
}

.view-all:hover {
  color: #E31E24;
  transform: translateX(-4px);
}

/* Performers List */
.performers-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.performer-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: linear-gradient(135deg, #f8fafc, #f1f5f9);
  border-radius: 14px;
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.modern-admin.dark .performer-item {
  background: linear-gradient(135deg, #334155, #1e293b);
}

.performer-item:hover {
  transform: translateX(-6px);
  border-color: #003DA5;
  box-shadow: 0 8px 24px rgba(0, 61, 165, 0.2);
}

.performer-rank {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  font-weight: 800;
  flex-shrink: 0;
}

.performer-rank .gold {
  color: #f59e0b;
  filter: drop-shadow(0 4px 8px rgba(245, 158, 11, 0.4));
}

.performer-rank .silver {
  color: #94a3b8;
  filter: drop-shadow(0 4px 8px rgba(148, 163, 184, 0.4));
}

.performer-rank .bronze {
  color: #d97706;
  filter: drop-shadow(0 4px 8px rgba(217, 119, 6, 0.4));
}

.performer-rank span {
  color: #64748b;
  font-size: 1.1rem;
}

.performer-info {
  flex: 1;
}

.performer-info h4 {
  font-size: 1rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 4px 0;
}

.modern-admin.dark .performer-info h4 {
  color: white;
}

.performer-info p {
  font-size: 0.85rem;
  color: #64748b;
  margin: 0;
}

.modern-admin.dark .performer-info p {
  color: #94a3b8;
}

.performer-points {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: linear-gradient(135deg, #003DA5, #0052d4);
  color: white;
  border-radius: 20px;
  font-weight: 800;
  font-size: 1rem;
  box-shadow: 0 4px 12px rgba(0, 61, 165, 0.3);
}

.performer-points svg {
  color: #fbbf24;
}

/* Activity List */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.activity-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px;
  background: #f8fafc;
  border-radius: 14px;
  border-right: 4px solid transparent;
  transition: all 0.3s ease;
}

.modern-admin.dark .activity-item {
  background: #334155;
}

.activity-item:hover {
  transform: translateX(-4px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
}

.activity-item.user {
  border-right-color: #003DA5;
}

.activity-item.event {
  border-right-color: #10b981;
}

.activity-item.task {
  border-right-color: #f59e0b;
}

.activity-item.pending {
  border-right-color: #E31E24;
}

.activity-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}

.activity-item.user .activity-icon {
  background: rgba(0, 61, 165, 0.15);
  color: #003DA5;
}

.activity-item.event .activity-icon {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.activity-item.task .activity-icon {
  background: rgba(245, 158, 11, 0.15);
  color: #f59e0b;
}

.activity-item.pending .activity-icon {
  background: rgba(227, 30, 36, 0.15);
  color: #E31E24;
}

.activity-content {
  flex: 1;
}

.activity-content p {
  font-size: 0.95rem;
  font-weight: 600;
  color: #1e293b;
  margin: 0 0 4px 0;
}

.modern-admin.dark .activity-content p {
  color: white;
}

.activity-content span {
  font-size: 0.8rem;
  color: #94a3b8;
}

.no-data {
  text-align: center;
  color: #94a3b8;
  padding: 40px 20px;
  font-size: 1rem;
}

/* Responsive for Bottom Section */
@media (max-width: 1024px) {
  .bottom-section {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .section-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .performer-item {
    padding: 12px;
  }

  .performer-rank {
    width: 36px;
    height: 36px;
    font-size: 1.2rem;
  }

  .performer-info h4 {
    font-size: 0.9rem;
  }

  .performer-info p {
    font-size: 0.75rem;
  }

  .performer-points {
    padding: 6px 12px;
    font-size: 0.9rem;
  }
}

/* Progress Ring for Tasks */
.stat-card.warning .stat-header {
  position: relative;
}

.progress-ring {
  position: absolute;
  top: -10px;
  left: -10px;
  width: 76px;
  height: 76px;
}

.progress-ring-circle {
  transition: stroke-dashoffset 0.8s ease;
  transform: rotate(-90deg);
  transform-origin: 50% 50%;
}

/* Enhanced Hover Effects */
.stat-card::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 61, 165, 0.1), transparent);
  transform: translate(-50%, -50%);
  transition: width 0.6s ease, height 0.6s ease;
}

.stat-card:hover::after {
  width: 300px;
  height: 300px;
}

/* Animated Background Gradient */
@keyframes gradientShift {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.stat-icon {
  background-size: 200% 200%;
  animation: gradientShift 3s ease infinite;
}

/* Floating Animation for Icons */
@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8px);
  }
}

.info-icon {
  animation: float 3s ease-in-out infinite;
}

.info-icon.trophy {
  animation-delay: 0s;
}

.info-icon.users {
  animation-delay: 0.5s;
}

/* Shimmer Effect on Hover */
@keyframes shimmer {
  0% {
    background-position: -1000px 0;
  }
  100% {
    background-position: 1000px 0;
  }
}

.action-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  transition: left 0.5s ease;
}

.action-btn:hover::after {
  left: 100%;
}

/* Glow Effect for Stats */
.stat-card:hover .stat-icon {
  filter: drop-shadow(0 0 20px currentColor);
}

/* Smooth Number Counter Animation */
@keyframes countUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stat-card h3 {
  animation: countUp 0.6s ease-out;
}

/* Badge Pulse Animation */
@keyframes badgePulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 0 0 8px rgba(239, 68, 68, 0);
  }
}

.nav-link .badge {
  animation: badgePulse 2s infinite;
}

/* Scrollbar Styling */
.sidebar-nav::-webkit-scrollbar {
  width: 6px;
}

.sidebar-nav::-webkit-scrollbar-track {
  background: transparent;
}

.sidebar-nav::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 10px;
}

.modern-admin.dark .sidebar-nav::-webkit-scrollbar-thumb {
  background: #475569;
}

.sidebar-nav::-webkit-scrollbar-thumb:hover {
  background: #003DA5;
}

/* Tooltip Effect */
.icon-btn {
  position: relative;
}

.icon-btn::before {
  content: attr(data-tooltip);
  position: absolute;
  bottom: -40px;
  left: 50%;
  transform: translateX(-50%) scale(0);
  background: #1e293b;
  color: white;
  padding: 6px 12px;
  border-radius: 8px;
  font-size: 0.8rem;
  white-space: nowrap;
  opacity: 0;
  transition: all 0.3s ease;
  pointer-events: none;
}

.icon-btn:hover::before {
  transform: translateX(-50%) scale(1);
  opacity: 1;
}

/* Glass Morphism Effect for Cards on Hover */
.stat-card:hover,
.info-card:hover {
  backdrop-filter: blur(10px);
  background: rgba(255, 255, 255, 0.95);
}

.modern-admin.dark .stat-card:hover,
.modern-admin.dark .info-card:hover {
  background: rgba(30, 41, 59, 0.95);
}

/* Analytics Section */
.analytics-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-bottom: 32px;
}

.analytics-card {
  background: #23283a;
  border-radius: 20px;
  padding: 28px;
  border: 1px solid #2d3748;
}

.analytics-card h3 {
  color: white;
  font-size: 1.2rem;
  font-weight: 700;
  margin: 0 0 24px 0;
}

/* Sessions By Channel */
.channel-bars {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.channel-item {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.channel-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.channel-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}

.channel-name {
  color: #94a3b8;
  font-size: 0.9rem;
  font-weight: 600;
}

.channel-bar-container {
  width: 100%;
  height: 32px;
  background: #2d3748;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
}

.channel-bar {
  height: 100%;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12px;
  transition: width 0.8s ease;
}

.channel-percentage {
  color: white;
  font-weight: 700;
  font-size: 0.85rem;
}

/* Sessions Device */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.filter-select {
  background: #2d3748;
  border: 1px solid #374151;
  color: white;
  padding: 8px 16px;
  border-radius: 8px;
  font-family: 'Cairo', sans-serif;
  font-weight: 600;
  cursor: pointer;
  outline: none;
}

.filter-select:hover {
  background: #374151;
}

.device-circle {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 32px 0;
}

.device-stats {
  margin-top: 32px;
}

.device-header {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 16px;
  padding: 12px 16px;
  color: #64748b;
  font-size: 0.85rem;
  font-weight: 600;
  border-bottom: 1px solid #2d3748;
  margin-bottom: 12px;
}

.device-row {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 16px;
  padding: 16px;
  background: #2d3748;
  border-radius: 12px;
  margin-bottom: 8px;
  align-items: center;
  transition: all 0.3s ease;
}

.device-row:hover {
  background: #374151;
  transform: translateX(-4px);
}

.device-name {
  display: flex;
  align-items: center;
  gap: 12px;
  color: white;
  font-weight: 600;
}

.device-name svg {
  font-size: 1.2rem;
  color: #34d399;
}

.device-value {
  color: white;
  font-weight: 700;
}

.device-change {
  color: #f87171;
  font-weight: 600;
}

/* Mobile Menu Toggle */
@media (max-width: 768px) {
  .menu-toggle {
    display: block;
  }

  .sidebar {
    transform: translateX(100%);
  }

  .sidebar.open {
    transform: translateX(0);
    width: 280px;
  }

  .main-content {
    margin-right: 0;
  }

  .stats-container {
    grid-template-columns: 1fr;
  }

  .analytics-section {
    grid-template-columns: 1fr;
  }

  .top-bar {
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  .top-bar-right {
    width: 100%;
    justify-content: space-between;
  }

  .date-picker-btn span {
    display: none;
  }
}

@media (max-width: 480px) {
  .stat-card {
    padding: 20px;
  }

  .stat-value {
    font-size: 2rem;
  }

  .device-header,
  .device-row {
    grid-template-columns: 2fr 1fr 1fr;
  }

  .device-header span:last-child,
  .device-row .device-change:last-child {
    display: none;
  }
}
