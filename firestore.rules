rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin Faces Collection - السماح بالقراءة والكتابة للجميع
    match /adminFaces/{document=**} {
      allow read, write: if true;
    }
    
    // Unauthorized Access Attempts - السماح بالقراءة والكتابة للجميع
    match /unauthorizedAccessAttempts/{document=**} {
      allow read, write: if true;
    }
    
    // Users Collection - إذا كانت موجودة
    match /users/{document=**} {
      allow read, write: if true;
    }
    
    // Registrations Collection - إذا كانت موجودة
    match /registrations/{document=**} {
      allow read, write: if true;
    }
    
    // Events Collection - إذا كانت موجودة
    match /events/{document=**} {
      allow read, write: if true;
    }
    
    // Tasks Collection - إذا كانت موجودة
    match /tasks/{document=**} {
      allow read, write: if true;
    }
    
    // Attendance Collection - إذا كانت موجودة
    match /attendance/{document=**} {
      allow read, write: if true;
    }
    
    // أي مجموعة أخرى
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
